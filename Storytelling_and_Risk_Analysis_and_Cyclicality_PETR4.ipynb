        "id": "x8L-qlvIJYp-"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "With the operating margins vector created, we trigger the `numpy` library to extract risk and volatility indicators with algorithmic precision."
      ],
      "metadata": {
        "id": "ohEVNUGnJcx_"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Statistical Calculations (The KPIs)\n",
        "\n",
        "# Extracting the vector (array) for calculation\n",
        "margins = df['Operating_Margin'].values\n",
        "\n",
        "margins"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "EveEm9JeJdyv",
        "outputId": "b705236c-dc1c-4cdc-ad58-c665d4687aaf"
      },
      "execution_count": 10,
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": [
              "array([0.26850403, 0.19441024, 0.44713565, 0.45685966, 0.37270359,\n",
              "       0.28659268, 0.29317715])"
            ]
          },
          "metadata": {},
          "execution_count": 10
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Calculations (ddof=0 ensures population standard deviation)\n",
        "mean_margin = np.mean(margins)\n",
        "volatility = np.std(margins, ddof=0)\n",
        "coef_variation = volatility / mean_margin\n",
        "historical_floor = np.min(margins)\n",
        "historical_ceiling = np.max(margins)"
      ],
      "metadata": {
        "id": "GSMYOFVfJuKA"
      },
      "execution_count": 11,
      "outputs": []
    },
