        "plt.title('Historical Evolution: Operating Margin (%)', fontsize=12, fontweight='bold', pad=10)\n",
        "plt.ylabel('%')\n",
        "plt.xlabel('Fiscal Year', fontsize=10, fontweight='bold')\n",
        "\n",
