      "metadata": {
        "id": "d8mTXkZdHso2"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 6.1 Operating Margin Calculation"
      ],
      "metadata": {
        "id": "pmF-Rk7PH0F1"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "df['Operating_Margin'] = df['EBIT'] / df['Net_Revenue']"
      ],
      "metadata": {
        "id": "2MYn2h0sIAQd"
      },
      "execution_count": 6,
      "outputs": []
