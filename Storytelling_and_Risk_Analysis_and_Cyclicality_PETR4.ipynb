        "        <h2 style=\"margin: 10px 0 0 0; font-size: 24px; color: #323130;\">{historical_floor:.2%}</h2>\n",
        "    </div>\n",
        "\n",
        "    <!-- Cartão 5: Teto -->\n",
        "    <div style=\"background-color: white; border-top: 4px solid #008272; border-radius: 4px; box-shadow: 0px 4px 6px rgba(0,0,0,0.1); padding: 15px 20px; text-align: center; width: 160px;\">\n",
        "        <p style=\"margin: 0; font-size: 12px; color: #605e5c; font-weight: 600;\">📈 Hist. Ceiling (Max)</p>\n",
