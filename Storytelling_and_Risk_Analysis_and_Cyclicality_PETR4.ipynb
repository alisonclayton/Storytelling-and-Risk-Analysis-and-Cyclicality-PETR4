    {
      "cell_type": "markdown",
      "source": [
        "Renaming the CSV columns name to clean system variables, ensuring code fluency."
      ],
      "metadata": {
        "id": "plcTPHe4GnlD"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "df = df.rename(columns={\n",
        "    'Net Revenue (A in R$ mi)': 'Net_Revenue',\n",
        "    'EBIT (B in R$ mi)': 'EBIT'\n",
        "})"
      ],
      "metadata": {
